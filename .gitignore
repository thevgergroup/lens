node_modules/
dist/
.env

# Chrome for Testing binary (downloaded via npx @puppeteer/browsers install chrome@stable)
chrome/

# agent-browser config (contains local absolute paths)
agent-browser.json

# agent-browser persistent Chrome profile (local dev only)
.browser-profile/
.lens-profile/

# Downloaded fixture images — tracked by DVC (dvc pull to restore)
# Individual image files are in DVC cache; .dvc pointer files are committed
/tests/fixtures/images/**/*.jpg
/tests/fixtures/images/**/*.jpeg
/tests/fixtures/images/**/*.png
/tests/fixtures/images/**/*.webp

# Test screenshots (visual artifacts, not source)
tests/integration/screenshots/

# Symlink to /tmp/lens-ext (local dev only)
lens-ext

# Safari Xcode build artifacts (not source)
safari-ext/Lens/build/
safari-ext/**/*.xcuserstate
safari-ext/**/xcuserdata/
safari-ext/**/*.xccheckout
safari-ext/**/*.moved-aside
safari-ext/**/DerivedData/

# Editor config (personal preferences)
.vscode/

# Firefox AMO upload state (generated by web-ext sign)
.amo-upload-uuid

# Trained model artifacts and TF.js runtime (large binaries — not in git)
lib/mobilenet-tfjs/
lib/tfjs/
lib/*.pt
lib/*.onnx
lib/*.keras
lib/mallet-weights.json

# Stray screenshots and design source files
*.pxd
icons/screenshot.png
icons/screenshot*.png
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*.png
